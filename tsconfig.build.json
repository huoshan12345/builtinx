{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "verbatimModuleSyntax": false
  },
  "exclude": [
    "dist",
    "node_modules",
    "test/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}