{
  "name": "builtinx",
  "version": "0.1.0",
  "description": "Extensions for JavaScript built-ins and web platform objects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "preinstall": "npx only-allow pnpm",
    "clean": "shx rm -rf dist/** && shx rm -f *.tgz",
    "dev": "vite",
    "build": "run-s clean && vite build && run-s build:dts",
    "build:dts": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "ncu": "npx npm-check-updates -u"
  },
  "devDependencies": {
    "@phiberber/pinst": "^3.0.1",
    "@types/node": "^25.6.0",
    "npm-run-all2": "^8.0.4",
    "shx": "^0.4.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0",
    "vitest-canvas-mock": "^1.1.4"
  }
}
